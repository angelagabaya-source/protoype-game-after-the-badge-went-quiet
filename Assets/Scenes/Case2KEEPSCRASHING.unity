  m_Script: {fileID: 11500000, guid: 61be2a710a161924da350f0b9c93cbaf, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::UIMessageSwapper
  pauseMessageText: {fileID: 1668871351}
  gameOverMessageText: {fileID: 835532305}
  pauseMessages:
  - Thank god you're really here, I got in the academy because my dad's a police
    chief fourty years ago.
  - Wife thinks we should've stayed in the city. And I said, in this economy?
  - No no take your time. It's no pressure.
  - I lied, there is pressure. The morgue usually doesn't keep bodies this long.
  - Think we should call it in?
  gameOverMessages:
  - Got distracted? You know who else got distracted? the victim. She's now in the
    morgue. Lets try again.
  - Maybe we should go get coffee?
  - Getting rusty, boss?
  - Worst case, we get accused of tampering with evidence.
